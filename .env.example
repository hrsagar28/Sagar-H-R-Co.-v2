VITE_FORM_ENDPOINT=/api/contact   # Netlify redirects this to the contact function
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Anti-bot (Botpoison). These two MUST be set together, or BOTH left unset.
# If only one is present the contact/careers forms reject every submission (CF-4):
#  - public key set but secret missing  -> client solves, server can't verify
#  - secret set but public key missing   -> client sends nothing, server rejects (422)
VITE_BOTPOISON_PUBLIC_KEY=pk_replace_me_or_leave_blank
BOTPOISON_SECRET_KEY=sk_replace_me_or_leave_blank

# REQUIRED for the contact form to work.
# 1. Create a form at https://formsubmit.co and complete the ONE-TIME email
#    activation (FormSubmit emails you a link the first time — it will not send
#    anything until you click it).
# 2. Paste your real AJAX endpoint below AND set the same value in the Netlify UI
#    (Site settings > Environment variables).
# The function fails closed (returns "temporarily unavailable") until this is a
# real, activated https://formsubmit.co/ajax/... address — it will never fall
# back to a shared/placeholder alias.
FORM_SUBMIT_ENDPOINT=https://formsubmit.co/ajax/REPLACE_WITH_YOUR_ACTIVATED_ID
